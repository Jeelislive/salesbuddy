{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@salesbuddy/shared-types": ["libs/shared/types/src/index.ts"],
      "@salesbuddy/shared-utils": ["libs/shared/utils/src/index.ts"],
      "@salesbuddy/shared-constants": ["libs/shared/constants/src/index.ts"],
      "@salesbuddy/ui": ["libs/ui/src/index.ts"],
      "@salesbuddy/db": ["libs/db/src/index.ts"],
      "@salesbuddy/ai": ["libs/ai/src/index.ts"],
      "@salesbuddy/queue": ["libs/queue/src/index.ts"],
      "@salesbuddy/api-client": ["libs/api-client/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
