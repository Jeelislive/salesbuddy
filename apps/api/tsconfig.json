{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@salesbuddy/db": ["../../libs/db/src/index.ts"],
      "@salesbuddy/queue": ["../../libs/queue/src/index.ts"],
      "@salesbuddy/ai": ["../../libs/ai/src/index.ts"],
      "@salesbuddy/shared-types": ["../../libs/shared/types/src/index.ts"],
      "@salesbuddy/shared-utils": ["../../libs/shared/utils/src/index.ts"],
      "@salesbuddy/shared-constants": ["../../libs/shared/constants/src/index.ts"]
    }
  },
  "include": [
    "src/**/*",
    "../../libs/db/src/**/*",
    "../../libs/queue/src/**/*",
    "../../libs/ai/src/**/*",
    "../../libs/shared/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
